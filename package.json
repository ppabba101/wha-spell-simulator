{
  "name": "witch-hat-atelier-spell-simulator",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173",
    "start": "npm run dev",
    "build": "vite build",
    "test": "node --test \"tests/**/*.test.js\"",
    "test:integration": "node --test \"tests/**/*.integration.js\" \"worker/wha-llm-proxy/test/integration.test.js\"",
    "test:all": "npm test && npm run test:integration",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "golden:update": "playwright test --update-snapshots",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy"
  },
  "dependencies": {
    "@pixi/filter-advanced-bloom": "^5.1.1",
    "ajv": "^8.17.1",
    "perfect-freehand": "^1.2.3",
    "pixi.js": "^8.18.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "@playwright/test": "^1.48.2",
    "fast-check": "^3.23.2",
    "miniflare": "^3.20241218.0",
    "vite": "^6.4.0"
  }
}
